# ==============================================================
# 基于 LLM Agent 与规则推理的政务数据决策系统 - 配置模板
# 使用方式：复制本文件为 config/.env，填入真实值
# 注意：.env 文件已加入 .gitignore，不要上传到代码仓库
# ==============================================================


# --------------------------------------------------------------
# LLM 配置
# 支持提供商（LLM_PROVIDER 可选值）：
#   nova        → Nova AI 第三方中转 API（推荐，兼容 OpenAI 格式）
#   openai      → OpenAI 官方 API（GPT-4o / GPT-4 等）
#   deepseek    → DeepSeek API（兼容 OpenAI 格式）
#   dashscope   → 阿里云通义千问（兼容 OpenAI 格式）
#   zhipu       → 智谱 GLM（兼容 OpenAI 格式）
#   anthropic   → Anthropic Claude（独立 SDK）
# --------------------------------------------------------------
LLM_PROVIDER=nova

# API Key（填入你在 novai.su “令牌管理”里创建的 sk- 开头的密鑰）
LLM_API_KEY=

# API Base URL（Nova 中转配置了默认地址，选填）
# Nova:      https://once.novai.su/v1  ← 默认已内置，可不填
# OpenAI:   https://api.openai.com/v1 ← 官方默认，可不填
# DeepSeek:  https://api.deepseek.com/v1
# 通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱:      https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=

# 模型名称（Nova 支持多种模型，参考其文档选择）
# Nova 示例：  [次]gemini-3-pro-preview   |  [次]gpt-4.5-preview
# OpenAI:    gpt-4o | gpt-4-turbo
# DeepSeek:  deepseek-chat | deepseek-reasoner
# 通义千问:  qwen-plus | qwen-max
# Claude:    claude-3-5-sonnet-20241022
LLM_MODEL=[次]gemini-3-pro-preview

# 生成参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096


# --------------------------------------------------------------
# 数据库配置（MySQL 8.0+）
# --------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bysj_t2s
DB_CHARSET=utf8mb4


# --------------------------------------------------------------
# 系统运行参数
# --------------------------------------------------------------
# 模拟系统当前日期（本项目固定为 2026-03-21）
SYSTEM_DATE=2026-03-21

# 辩论最大轮数（不超过 2）
DEBATE_MAX_ROUNDS=2

# 共识阈值：达到该比例的 Agent 结论一致即视为形成共识（0~1）
# 5个Agent中 4/5=0.8，即4位一致就停止辩论
CONSENSUS_THRESHOLD=0.8

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
